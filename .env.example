# ┌──────────────────────────────────────────────────────────┐
# │         KanoonSaathi — Environment Configuration        │
# │                                                         │
# │  Copy this file to .env and fill in your values:       │
# │  cp .env.example .env                                   │
# └──────────────────────────────────────────────────────────┘

# ─── Core ────────────────────────────────────────────────────
NODE_ENV=development          # 'development' or 'production'
PORT=3001                      # API server port

# ─── AI Provider ─────────────────────────────────────────────
AI_PROVIDER=gemini             # 'gemini', 'openai', 'anthropic', 'nvidia', or 'mock'

# Gemini (recommended — free tier available)
GEMINI_API_KEY=your_gemini_api_key_here

# NVIDIA NIM (free evaluation at build.nvidia.com)
# NVIDIA_API_KEY=nvapi-...

# OpenAI (alternative)
# OPENAI_API_KEY=sk-...

# Anthropic (alternative)
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Database ────────────────────────────────────────────────
DB_PROVIDER=sqlite             # 'sqlite' (local) or 'mongodb' (cloud)

# MongoDB Atlas — required if DB_PROVIDER=mongodb
# Free tier: https://cloud.mongodb.com
# MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/kanoonsaathi?retryWrites=true&w=majority

# SQLite Backups — auto-backup every N hours (prod only)
# ENABLE_BACKUPS=true
# BACKUP_INTERVAL_HOURS=24

# ─── Authentication ──────────────────────────────────────────
# ⚠️ CHANGE THESE IN PRODUCTION!
JWT_SECRET=kanoonsaathi-dev-secret-change-in-prod

# Admin account seeded on first run
ADMIN_EMAIL=admin@kanoonsaathi.in
ADMIN_PASSWORD=admin123

# ─── Security ────────────────────────────────────────────────
# CORS origins (comma-separated, required in production)
# CORS_ORIGIN=https://kanoonsaathi.in,https://www.kanoonsaathi.in
